# AI API Keys
# Rename this file to .env and fill in your keys
# NOTE: For Vite to see these in the frontend, they strictly need the VITE_ prefix.

# Google Gemini API (Recommended)
# Get your key at: https://aistudio.google.com/
VITE_GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# OpenAI API
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude) API
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Preferred Model Configuration
VITE_PREFERRED_MODEL=gemini-1.5-flash
