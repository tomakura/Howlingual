{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-apphowlingual",
  "version": "0.1.0",
  "identifier": "com.howlingual.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Howlingual",
        "url": "/?view=main",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "transparent": true,
        "visible": false
      },
      {
        "label": "tray",
        "title": "Howlingual Tray",
        "url": "/tray",
        "width": 180,
        "height": 110,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": false
      },
      {
        "label": "capture",
        "title": "Howlingual Capture",
        "url": "/?view=capture",
        "decorations": false,
        "fullscreen": false,
        "resizable": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "service",
        "title": "Howlingual Service",
        "url": "/service",
        "width": 100,
        "height": 100,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}