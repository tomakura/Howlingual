{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Howlingual",
  "version": "1.2.0",
  "identifier": "com.howlingual.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "service",
        "title": "Howlingual Service",
        "url": "/service",
        "width": 100,
        "height": 100,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "windows": {
      "wix": {
        "language": [
          "en-US",
          "ja-JP"
        ]
      },
      "nsis": {
        "languages": [
          "English",
          "Japanese"
        ],
        "displayLanguageSelector": true
      }
    }
  }
}